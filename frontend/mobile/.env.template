


EXPO_PUBLIC_STAGE=dev

EXPO_PUBLIC_API_URL=http://192.168.1.14:8081
EXPO_PUBLIC_API_URL_IOS=http://localhost:8081
EXPO_PUBLIC_API_URL_ANDROID=http://192.168.1.14:8081

# API Gateway base URL. Used by waiter/kitchen orders to route REST traffic
# through the single ingress (rewrites /order/** -> /api/orders/** and
# /menu/**  -> /api/menus/** inside the gateway).
EXPO_PUBLIC_GATEWAY_URL=http://192.168.1.14:8080
EXPO_PUBLIC_GATEWAY_URL_IOS=http://localhost:8080
EXPO_PUBLIC_GATEWAY_URL_ANDROID=http://192.168.1.14:8080

# Direct WebSocket endpoint for the OrderService kitchen channel. The MVC
# flavor of Spring Cloud Gateway does not transparently proxy WebSocket
# upgrades, so clients connect directly to OrderService :8085.
EXPO_PUBLIC_ORDER_WS_URL=ws://192.168.1.14:8085/ws/kitchen
EXPO_PUBLIC_ORDER_WS_URL_IOS=ws://localhost:8085/ws/kitchen
EXPO_PUBLIC_ORDER_WS_URL_ANDROID=ws://192.168.1.14:8085/ws/kitchen

# Until waiters can be tied to a restaurant via JWT claim, the waiter app
# reads its restaurantId from an env var. Production should replace this
# with a claim-based lookup on the token.
EXPO_PUBLIC_WAITER_RESTAURANT_ID=1