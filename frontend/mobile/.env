EXPO_PUBLIC_STAGE=dev

# Legacy auth/restaurants flow (productsApi)
EXPO_PUBLIC_API_URL=http://192.168.5.113:8080
EXPO_PUBLIC_API_URL_IOS=http://localhost:8080
EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2:8080

# API Gateway (REST – waiter/orders/menus go through the gateway)
EXPO_PUBLIC_GATEWAY_URL=http://192.168.5.113:8080
EXPO_PUBLIC_GATEWAY_URL_IOS=http://localhost:8080
EXPO_PUBLIC_GATEWAY_URL_ANDROID=http://10.0.2.2:8080

# STOMP/WebSocket (realtime kitchen events, proxied by the gateway on 8080)
EXPO_PUBLIC_ORDER_WS_URL=ws://192.168.5.113:8080/ws/kitchen
EXPO_PUBLIC_ORDER_WS_URL_IOS=ws://localhost:8080/ws/kitchen
EXPO_PUBLIC_ORDER_WS_URL_ANDROID=ws://10.0.2.2:8080/ws/kitchen

# Hardcoded fallback until the waiter's restaurant can be inferred from the JWT
EXPO_PUBLIC_WAITER_RESTAURANT_ID=1
