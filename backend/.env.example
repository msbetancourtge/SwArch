# Click & Munch — backend environment template.
# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is git-ignored; this template is committed and must contain NO secrets.
#
#   cp .env.example .env
#   # then edit .env with your own values (or generate them, see below)
#
# Generate strong values:
#   POSTGRES_PASSWORD / MONGO_PASSWORD / RABBITMQ_PASSWORD:  openssl rand -hex 16
#   JWT_SECRET:                                              openssl rand -base64 48

# --- PostgreSQL (shared dev credentials across all service databases) ---
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme

# --- MongoDB (MenuService) ---
MONGO_USER=changeme
MONGO_PASSWORD=changeme

# --- RabbitMQ (Order/Reservation/Notification messaging) ---
RABBITMQ_USER=changeme
RABBITMQ_PASSWORD=changeme

# --- JWT signing secret ---
# MUST be identical for AuthService and APIGateway, otherwise token
# validation at the gateway will reject all AuthService-issued tokens.
JWT_SECRET=changeme

# --- Dev/QA data seeding (optional) ---
# When true, services preload idempotent demo data on startup:
#   AuthService -> one APPROVED user per role (qa_customer/manager/waiter/chef/admin)
#   MenuService -> demo menus per restaurant
# Leave true for local/QA; set false for production. Never enable in prod.
APP_SEED_ENABLED=true
# Password assigned to every seeded test user (dev-only, not a production secret).
APP_SEED_PASSWORD=Password123!
