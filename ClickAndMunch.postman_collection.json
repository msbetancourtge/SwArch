							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"resetToken\": \"<token-from-email>\",\n    \"newPassword\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/auth/password-reset/confirm",
							"host": ["http://localhost:8081"],
							"path": ["auth", "password-reset", "confirm"]
						},
						"description": "Confirm a password reset with the token received via email. NOTE: Direct call to AuthService (port 8081)."
					},
					"response": []
