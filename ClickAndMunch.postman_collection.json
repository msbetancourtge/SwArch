							"raw": "{\n    \"email\": \"test@example.com\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/auth/password-reset/request",
							"host": ["http://localhost:8081"],
							"path": ["auth", "password-reset", "request"]
						},
						"description": "Request a password reset email. NOTE: This endpoint is called directly on AuthService (port 8081) because the controller path doesn't follow the /api prefix convention."
					},
					"response": []
